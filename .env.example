# ── Server ──────────────────────────────────────────────
PORT=3000

# ── Cloud Selection ─────────────────────────────────────
# Built-in profiles: azure-commercial, azure-us-government,
#   azure-us-gov-secret, azure-us-gov-topsecret, azurestack-custom
# For Secret/TopSecret/AzureStack: update the placeholder endpoints
# in the matching cloud-profiles/*.json file.
AZURE_CLOUD=azure-us-government

# ── Authentication ──────────────────────────────────────
# Modes: managedIdentity, workloadIdentity, azureCli, deviceCode, clientSecret
# For deployed workloads, use managedIdentity (preferred) or workloadIdentity.
# For local dev, use azureCli (run 'az cloud set' + 'az login' first).
AUTH_MODE=azureCli
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_STORAGE_ACCOUNT=

# ── Custom Cloud Profile ───────────────────────────────
# Path to a JSON file matching cloud-profiles/schema.json.
# Use this for clouds not covered by built-in profiles.
CUSTOM_CLOUD_PROFILE_PATH=

# ── Per-Cloud Endpoint Overrides ───────────────────────
# These override values from the selected cloud profile.
# Required for AzureStack Hub and private clouds where
# endpoints differ from the built-in profile defaults.
#
# IMPORTANT: For AzureStack, Secret, and Top Secret clouds,
# the app automatically sets disableInstanceDiscovery=true
# when the authority host is not a well-known Microsoft endpoint.
# No manual configuration is needed for this — it's auto-detected
# from the authorityHost value below.
AZURE_AUTHORITY_HOST=
AZURE_RESOURCE_MANAGER_ENDPOINT=
AZURE_RESOURCE_MANAGER_AUDIENCE=

# ── Service DNS Suffix Overrides ───────────────────────
# Override DNS suffixes for service endpoints.
# These must start with "." (e.g., ".blob.core.usgovcloudapi.net").
AZURE_STORAGE_DNS_SUFFIX=
AZURE_KEYVAULT_DNS_SUFFIX=
AZURE_SQL_DNS_SUFFIX=
AZURE_ACR_DNS_SUFFIX=

# ── Service Audience Overrides ─────────────────────────
# Override token audiences for data-plane services.
AZURE_STORAGE_AUDIENCE=
AZURE_KEYVAULT_AUDIENCE=
