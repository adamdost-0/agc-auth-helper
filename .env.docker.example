# Copy to .env.docker.local and fill in values for local container testing.
# Keep .env.docker.local out of git; it contains credentials.

AZURE_CLOUD=azure-commercial
AUTH_MODE=clientSecret
AZURE_TENANT_ID=<tenant-id>
AZURE_CLIENT_ID=<service-principal-client-id>
AZURE_CLIENT_SECRET=<service-principal-client-secret>
AZURE_SUBSCRIPTION_ID=<subscription-id>

# Optional: only needed to test /api/blob-containers.
AZURE_STORAGE_ACCOUNT=<storage-account-name>

# Optional: use these overrides for Azure Stack Hub, private, or custom Azure clouds.
# AZURE_CLOUD=azurestack-custom
# AZURE_AUTHORITY_HOST=https://login.mystack.contoso.local/
# AZURE_RESOURCE_MANAGER_ENDPOINT=https://management.mystack.contoso.local/
# AZURE_RESOURCE_MANAGER_AUDIENCE=https://management.mystack.contoso.local/
# AZURE_STORAGE_DNS_SUFFIX=.blob.storage.mystack.contoso.local
# AZURE_STORAGE_AUDIENCE=https://storage.mystack.contoso.local/

# Optional: local path to a PEM file with the private root/intermediate CA chain.
# Required only when using docker-compose.private-ca.yml.
# The PEM is bind-mounted into the container and trusted via NODE_EXTRA_CA_CERTS.
# AGC_AUTH_HELPER_CA_BUNDLE=./certs/private-cloud-ca.pem
